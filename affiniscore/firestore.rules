rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || exists(/databases/$(database)/documents/couples/$(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.coupleId)));
      allow create: if isSignedIn() && request.auth.uid == userId 
        && incoming().uid == userId
        && incoming().xp == 0
        && incoming().level == 1;
      allow update: if isSignedIn() && request.auth.uid == userId
        && incoming().uid == userId
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'partnerId', 'coupleId', 'xp', 'level', 'streak']);
    }

    // 2. Couples Collection
    match /couples/{coupleId} {
      allow get: if isSignedIn() && (existing().user1Id == request.auth.uid || existing().user2Id == request.auth.uid);
      allow create: if isSignedIn() && (incoming().user1Id == request.auth.uid || incoming().user2Id == request.auth.uid);
      allow update: if isSignedIn() && (existing().user1Id == request.auth.uid || existing().user2Id == request.auth.uid)
        && incoming().diff(existing()).affectedKeys().hasOnly(['sharedXP', 'streakCount']);
      
      // 3. Missions Subcollection
      match /missions/{missionId} {
        allow list, get: if isSignedIn() && (get(/databases/$(database)/documents/couples/$(coupleId)).data.user1Id == request.auth.uid || get(/databases/$(database)/documents/couples/$(coupleId)).data.user2Id == request.auth.uid);
        allow create: if isSignedIn() && (get(/databases/$(database)/documents/couples/$(coupleId)).data.user1Id == request.auth.uid || get(/databases/$(database)/documents/couples/$(coupleId)).data.user2Id == request.auth.uid)
          && incoming().coupleId == coupleId;
        allow update: if isSignedIn() && (get(/databases/$(database)/documents/couples/$(coupleId)).data.user1Id == request.auth.uid || get(/databases/$(database)/documents/couples/$(coupleId)).data.user2Id == request.auth.uid)
          && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'title', 'description', 'xpReward']);
        allow delete: if isSignedIn() && (get(/databases/$(database)/documents/couples/$(coupleId)).data.user1Id == request.auth.uid || get(/databases/$(database)/documents/couples/$(coupleId)).data.user2Id == request.auth.uid);
      }
    }
  }
}
